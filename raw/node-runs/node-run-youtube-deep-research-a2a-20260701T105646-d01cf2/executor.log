#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
import re
import sys
import time
import urllib.error
import urllib.request
from datetime import datetime, timezone
from pathlib import Path
from typing import Any


FINAL_OK = {"done", "completed", "complete", "success", "succeeded"}
FINAL_BAD = {"failed", "error", "cancelled", "canceled"}
YOUTUBE_URL_RE = re.compile(
    r"https?://(?:www\.)?(?:youtube\.com/watch\?v=[A-Za-z0-9_-]+[^\s\"'<>)]*|youtu\.be/[A-Za-z0-9_-]+[^\s\"'<>)]*)"
)


def utc_now() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def parse_bool(value: str) -> bool:
    return str(value or "").strip().lower() in {"1", "true", "yes", "y", "on"}


def validate_source_url(value: str) -> str:
    source_url = str(value or "").strip()
    if not source_url or not YOUTUBE_URL_RE.search(source_url):
        raise RuntimeError("source_url must be a YouTube watch or youtu.be URL")
    return source_url


def request_json(url: str, token: str, method: str = "GET", data: dict[str, Any] | None = None, timeout: int = 120) -> dict[str, Any]:
    payload = json.dumps(data).encode("utf-8") if data is not None else None
    headers = {
        "Accept": "application/json",
        "Content-Type": "application/json",
        "User-Agent": os.environ.get("YOUTUBE_RESEARCH_WORKFLOW_USER_AGENT", "curl/8.7.1"),
    }
    if token:
        headers["Authorization"] = f"Bearer {token}"
    req = urllib.request.Request(url, data=payload, method=method, headers=headers)
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return json.loads(resp.read().decode("utf-8"))
    except urllib.error.HTTPError as exc:
        body = exc.read().decode("utf-8", errors="replace")
        raise RuntimeError(f"workflow API HTTP {exc.code}: {body or exc.reason}") from exc
    except urllib.error.URLError as exc:
        raise RuntimeError(f"workflow API request failed: {exc}") from exc


def request_text(url: str, token: str, timeout: int = 180) -> str:
    headers = {"User-Agent": os.environ.get("YOUTUBE_RESEARCH_WORKFLOW_USER_AGENT", "curl/8.7.1")}
    if token:
        headers["Authorization"] = f"Bearer {token}"
    req = urllib.request.Request(url, method="GET", headers=headers)
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return resp.read().decode("utf-8", errors="replace")
    except urllib.error.HTTPError as exc:
        body = exc.read().decode("utf-8", errors="replace")
        raise RuntimeError(f"workflow file HTTP {exc.code}: {body or exc.reason}") from exc
    except urllib.error.URLError as exc:
        raise RuntimeError(f"workflow file request failed: {exc}") from exc


def poll_job(base_url: str, token: str, job_id: str, timeout_seconds: int, poll_interval: int) -> dict[str, Any]:
    deadline = time.time() + max(5, timeout_seconds)
    interval = max(1, poll_interval)
    last: dict[str, Any] = {}
    while time.time() < deadline:
        last = request_json(f"{base_url.rstrip('/')}/status/{job_id}", token, method="GET")
        status = str(last.get("status") or "").lower()
        print(f"[youtube-deep-research] job={job_id} status={status or 'unknown'}", file=sys.stderr, flush=True)
        if status in FINAL_OK:
            return last
        if status in FINAL_BAD:
            raise RuntimeError(f"workflow failed: {last.get('error') or status}")
        time.sleep(interval)
    raise TimeoutError(f"workflow timeout after {timeout_seconds}s, last_status={last.get('status')}")


def title_from_status(status: dict[str, Any]) -> str:
    titles = status.get("titles")
    if isinstance(titles, list) and titles:
        return str(titles[0])
    if isinstance(titles, str):
        return titles
    return str(status.get("youtube_url") or status.get("id") or "YouTube Deep Research")


def markdown_from_status(status: dict[str, Any], downloaded: dict[str, str], include_transcript: bool) -> str:
    lines = [
        f"# YouTube Deep Research: {title_from_status(status)}",
        "",
        "## Basic Info",
        "",
        f"- YouTube: {status.get('youtube_url', '')}",
        f"- Job ID: {status.get('id', '')}",
        f"- Status: {status.get('status', '')}",
        f"- Detected language: {status.get('detected_lang') or ''}",
        f"- Model: {status.get('model_used') or ''}",
        "",
    ]
    if status.get("summary"):
        lines += ["## Summary", "", str(status["summary"]), ""]
    key_points = status.get("key_points")
    if key_points:
        lines += ["## Key Points", ""]
        if isinstance(key_points, list):
            lines += [f"- {item}" for item in key_points]
        else:
            lines.append(str(key_points))
        lines.append("")
    clip_suggestions = status.get("clip_suggestions")
    if clip_suggestions:
        lines += ["## Clip Suggestions", ""]
        if isinstance(clip_suggestions, list):
            lines += [f"- {item}" for item in clip_suggestions]
        else:
            lines.append(str(clip_suggestions))
        lines.append("")
    files = status.get("files") or {}
    if isinstance(files, dict) and files:
        lines += ["## Worker Files", ""]
        for key in sorted(files):
            lines.append(f"- {key}: {files[key]}")
        lines.append("")
    chunks = status.get("chunks") or []
    if isinstance(chunks, list) and chunks:
        lines += ["## Chunk Status", ""]
        for chunk in chunks:
            if not isinstance(chunk, dict):
                continue
            lines.append(
                f"- chunk {chunk.get('chunk_index')}: {chunk.get('status')} "
                f"start={chunk.get('start_sec')} transcript={chunk.get('transcript_url') or ''}"
            )
        lines.append("")
    if downloaded.get("analysis_md"):
        lines += ["## Worker Analysis Markdown", "", downloaded["analysis_md"][:12000], ""]
    if include_transcript and downloaded.get("transcript_txt"):
        lines += ["## Transcript", "", downloaded["transcript_txt"][:30000], ""]
    return "\n".join(lines).rstrip() + "\n"


def write_file(root: Path, name: str, content: str) -> str:
    root.mkdir(parents=True, exist_ok=True)
    path = root / name
    path.write_text(content, encoding="utf-8")
    return str(path)


def write_json_file(root: Path, name: str, payload: dict[str, Any]) -> str:
    return write_file(root, name, json.dumps(payload, ensure_ascii=False, indent=2) + "\n")


def run_research(args: argparse.Namespace) -> dict[str, Any]:
    source_url = validate_source_url(args.source_url)
    workflow_url = str(args.workflow_url or "").strip().rstrip("/")
    workflow_token = str(args.workflow_token or "").strip()
    if not workflow_url:
        raise RuntimeError("workflow_url is required. Set --workflow-url or YOUTUBE_RESEARCH_WORKFLOW_URL.")
    if not workflow_token:
        raise RuntimeError("workflow_token is required. Set --workflow-token or YOUTUBE_RESEARCH_WORKFLOW_TOKEN.")

    started = request_json(workflow_url, workflow_token, method="POST", data={"url": source_url})
    job_id = str(started.get("job_id") or started.get("id") or "").strip()
    if not job_id:
        raise RuntimeError(f"missing job_id in workflow response: {started}")
    status = poll_job(workflow_url, workflow_token, job_id, args.timeout_seconds, args.poll_interval)

    downloaded: dict[str, str] = {}
    worker_files = status.get("files") if isinstance(status.get("files"), dict) else {}
    output_root = Path(args.output_dir).expanduser() if args.output_dir else None
    written: dict[str, str] = {}

    for key, filename in (
        ("analysis_md", "worker-analysis.md"),
        ("transcript_txt", "transcript.txt"),
        ("transcript_srt", "transcript.srt"),
        ("transcript_vtt", "transcript.vtt"),
        ("transcript_json", "transcript.json"),
    ):
        url = worker_files.get(key) if isinstance(worker_files, dict) else ""
        if not url:
            continue
        try:
            text = request_text(str(url), workflow_token)
            downloaded[key] = text
            if output_root:
                written[key] = write_file(output_root, filename, text)
        except Exception as exc:
            print(f"[youtube-deep-research] download {key} failed: {exc}", file=sys.stderr, flush=True)

    analysis_md = markdown_from_status(status, downloaded, include_transcript=parse_bool(args.include_transcript))
    result = {
        "status": "succeeded",
        "source_url": source_url,
        "job_id": job_id,
        "workflow_status": status.get("status", ""),
        "fetched_at": utc_now(),
        "worker_files": worker_files,
        "written": written,
    }
    if output_root:
        written["analysis_file"] = write_file(output_root, "analysis.md", analysis_md)
        written["status_file"] = write_json_file(output_root, "status.json", status)
        written["start_file"] = write_json_file(output_root, "start.json", started)
        result["analysis_file"] = written["analysis_file"]
        if "transcript_txt" in written:
            result["transcript_file"] = written["transcript_txt"]
        result["status_file"] = written["status_file"]
        result["start_file"] = written["start_file"]
        written["result_file"] = write_json_file(output_root, "result.json", result)
        result["result_file"] = written["result_file"]
    else:
        result["analysis_markdown"] = analysis_md
        if downloaded.get("transcript_txt"):
            result["transcript_text"] = downloaded["transcript_txt"]
    return result


def main() -> int:
    parser = argparse.ArgumentParser(description="Run YouTube deep research through the configured Worker.")
    parser.add_argument("--source-url", required=True)
    parser.add_argument("--workflow-url", default=os.environ.get("YOUTUBE_RESEARCH_WORKFLOW_URL", ""))
    parser.add_argument(
        "--workflow-token",
        default=os.environ.get("YOUTUBE_RESEARCH_WORKFLOW_TOKEN") or os.environ.get("YOUTUBE_CONTENT_API_TOKEN", ""),
    )
    parser.add_argument("--timeout-seconds", type=int, default=int(os.environ.get("YOUTUBE_RESEARCH_WORKFLOW_TIMEOUT", "1200")))
    parser.add_argument("--poll-interval", type=int, default=int(os.environ.get("YOUTUBE_RESEARCH_WORKFLOW_POLL_INTERVAL", "10")))
    parser.add_argument("--output-dir", default="")
    parser.add_argument("--include-transcript", default="true")
    args = parser.parse_args()
    print(json.dumps(run_research(args), ensure_ascii=False, indent=2))
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except Exception as exc:
        print(json.dumps({"status": "failed", "error": str(exc)}, ensure_ascii=False), file=sys.stderr)
        raise SystemExit(1)

