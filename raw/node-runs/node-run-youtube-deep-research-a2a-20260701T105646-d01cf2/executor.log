#!/usr/bin/env bash
set -euo pipefail

load_private_env() {
  local env_file script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  for env_file in \
    "$script_dir/../.skill.env" \
    "$HOME/.agent-brain-plugins.env" \
    "$HOME/agent-brain-plugins/youtube-wiki/env.shared" \
    "$HOME/.hermes/.env"; do
    if [[ -f "$env_file" ]]; then
      set -a
      # shellcheck source=/dev/null
      source "$env_file"
      set +a
    fi
  done
}

load_private_env

SOURCE_URL=""
WORKFLOW_URL="${YOUTUBE_RESEARCH_WORKFLOW_URL:-}"
WORKFLOW_TOKEN="${YOUTUBE_RESEARCH_WORKFLOW_TOKEN:-${YOUTUBE_CONTENT_API_TOKEN:-}}"
TIMEOUT_SECONDS="${YOUTUBE_RESEARCH_WORKFLOW_TIMEOUT:-1200}"
POLL_INTERVAL="${YOUTUBE_RESEARCH_WORKFLOW_POLL_INTERVAL:-10}"
OUTPUT_DIR=""
INCLUDE_TRANSCRIPT="true"

usage() {
  cat >&2 <<'USAGE'
Usage:
  youtube-deep-research.sh --source-url https://www.youtube.com/watch?v=... [options]

Options:
  --source-url URL          Required YouTube source URL.
  --workflow-url URL        Worker base URL. Defaults to YOUTUBE_RESEARCH_WORKFLOW_URL.
  --workflow-token TOKEN    Worker bearer token. Defaults to YOUTUBE_RESEARCH_WORKFLOW_TOKEN.
  --timeout-seconds N       Workflow timeout seconds. Default: 1200.
  --poll-interval N         Poll interval seconds. Default: 10.
  --output-dir DIR          Optional directory for generated artifacts.
  --include-transcript BOOL true/false. Include transcript text in analysis.md. Default: true.
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --source-url) SOURCE_URL="${2:-}"; shift 2 ;;
    --workflow-url) WORKFLOW_URL="${2:-}"; shift 2 ;;
    --workflow-token) WORKFLOW_TOKEN="${2:-}"; shift 2 ;;
    --timeout-seconds) TIMEOUT_SECONDS="${2:-}"; shift 2 ;;
    --poll-interval) POLL_INTERVAL="${2:-}"; shift 2 ;;
    --output-dir) OUTPUT_DIR="${2:-}"; shift 2 ;;
    --include-transcript) INCLUDE_TRANSCRIPT="${2:-}"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) echo "Unknown argument: $1" >&2; usage; exit 2 ;;
  esac
done

if [[ -z "$SOURCE_URL" ]]; then
  echo "Missing --source-url" >&2
  exit 2
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
exec python3 "$SCRIPT_DIR/youtube_deep_research.py" \
  --source-url "$SOURCE_URL" \
  --workflow-url "$WORKFLOW_URL" \
  --workflow-token "$WORKFLOW_TOKEN" \
  --timeout-seconds "$TIMEOUT_SECONDS" \
  --poll-interval "$POLL_INTERVAL" \
  --output-dir "$OUTPUT_DIR" \
  --include-transcript "$INCLUDE_TRANSCRIPT"

