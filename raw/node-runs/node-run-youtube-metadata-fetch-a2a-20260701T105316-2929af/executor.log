#!/usr/bin/env bash
set -euo pipefail

load_private_env() {
  local env_file script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  for env_file in \
    "$script_dir/../.skill.env" \
    "$HOME/.agent-brain-plugins.env" \
    "$HOME/agent-brain-plugins/youtube-wiki/env.shared" \
    "$HOME/.hermes/.env"; do
    if [[ -f "$env_file" ]]; then
      set -a
      # shellcheck source=/dev/null
      source "$env_file"
      set +a
    fi
  done
}

load_private_env

SOURCE_URL=""
API_URL="${YOUTUBE_CONTENT_API_URL:-https://youtube-content-parse.hb67egcim4.workers.dev}"
API_TOKEN="${YOUTUBE_CONTENT_API_TOKEN:-${YOUTUBE_RESEARCH_WORKFLOW_TOKEN:-}}"
TIMEOUT_SECONDS="${YOUTUBE_METADATA_TIMEOUT_SECONDS:-30}"
OUTPUT_DIR=""
OUTPUT_JSON=""
INCLUDE_RAW="false"

usage() {
  cat >&2 <<'USAGE'
Usage:
  youtube-metadata-fetch.sh --source-url https://www.youtube.com/watch?v=... [options]

Options:
  --source-url URL          Required YouTube source URL.
  --api-url URL             API base URL. Defaults to YOUTUBE_CONTENT_API_URL.
  --api-token TOKEN         API bearer token. Defaults to YOUTUBE_CONTENT_API_TOKEN.
  --timeout-seconds N       HTTP timeout seconds. Default: 30.
  --output-dir DIR          Optional directory for metadata.json, source-url.txt, result.json.
  --output-json FILE        Optional explicit metadata JSON file path.
  --include-raw VALUE       true/false. Include raw API payload in result JSON.
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --source-url) SOURCE_URL="${2:-}"; shift 2 ;;
    --api-url) API_URL="${2:-}"; shift 2 ;;
    --api-token) API_TOKEN="${2:-}"; shift 2 ;;
    --timeout-seconds) TIMEOUT_SECONDS="${2:-}"; shift 2 ;;
    --output-dir) OUTPUT_DIR="${2:-}"; shift 2 ;;
    --output-json) OUTPUT_JSON="${2:-}"; shift 2 ;;
    --include-raw) INCLUDE_RAW="${2:-}"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) echo "Unknown argument: $1" >&2; usage; exit 2 ;;
  esac
done

if [[ -z "$SOURCE_URL" ]]; then
  echo "Missing --source-url" >&2
  exit 2
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
exec python3 "$SCRIPT_DIR/youtube_metadata_fetch.py" \
  --source-url "$SOURCE_URL" \
  --api-url "$API_URL" \
  --api-token "$API_TOKEN" \
  --timeout-seconds "$TIMEOUT_SECONDS" \
  --output-dir "$OUTPUT_DIR" \
  --output-json "$OUTPUT_JSON" \
  --include-raw "$INCLUDE_RAW"

