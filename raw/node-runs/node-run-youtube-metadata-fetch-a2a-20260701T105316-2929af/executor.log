#!/usr/bin/env python3
import argparse
import json
import os
import sys
import urllib.error
import urllib.request
from datetime import datetime, timezone
from pathlib import Path
from typing import Any


def utc_now() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def normalize_metadata(source_url: str, payload: dict[str, Any], include_raw: bool = False) -> dict[str, Any]:
    data = payload.get("data") if isinstance(payload.get("data"), dict) else payload
    result = {
        "video_id": str(data.get("video_id") or data.get("videoId") or ""),
        "title": str(data.get("title") or ""),
        "author": str(data.get("author") or data.get("channel") or data.get("channel_name") or ""),
        "published_at": str(data.get("published_at") or data.get("publishedAt") or data.get("publish_date") or ""),
        "youtube_url": str(data.get("youtube_url") or data.get("youtubeUrl") or data.get("url") or source_url),
        "thumbnail": str(data.get("thumbnail") or data.get("thumbnail_url") or data.get("thumbnailUrl") or ""),
        "source_url": source_url,
        "fetched_at": utc_now(),
    }
    if include_raw:
        result["raw"] = payload
    return result


def fetch_metadata(source_url: str, api_url: str, api_token: str, timeout_seconds: int) -> dict[str, Any]:
    if not api_url:
        raise RuntimeError("api_url is required. Set --api-url or YOUTUBE_CONTENT_API_URL.")

    body = json.dumps({"url": source_url}).encode("utf-8")
    headers = {
        "Content-Type": "application/json",
        "Accept": "application/json",
        "User-Agent": os.environ.get("YOUTUBE_CONTENT_API_USER_AGENT", "curl/8.7.1"),
    }
    if api_token:
        headers["Authorization"] = f"Bearer {api_token}"

    request = urllib.request.Request(
        f"{api_url.rstrip('/')}/transcript",
        data=body,
        headers=headers,
        method="POST",
    )
    try:
        with urllib.request.urlopen(request, timeout=timeout_seconds) as response:
            response_body = response.read().decode("utf-8")
    except urllib.error.HTTPError as exc:
        error_body = exc.read().decode("utf-8", errors="replace")
        raise RuntimeError(f"metadata API HTTP {exc.code}: {error_body}") from exc
    except urllib.error.URLError as exc:
        raise RuntimeError(f"metadata API request failed: {exc}") from exc

    payload = json.loads(response_body)
    if isinstance(payload, dict) and payload.get("success") is False:
        raise RuntimeError(f"metadata API returned failure: {payload}")
    return payload


def write_outputs(metadata: dict[str, Any], output_dir: str, output_json: str) -> dict[str, str]:
    written: dict[str, str] = {}
    if output_dir:
        root = Path(output_dir).expanduser()
        root.mkdir(parents=True, exist_ok=True)
        metadata_path = root / "metadata.json"
        source_path = root / "source-url.txt"
        result_path = root / "result.json"
        metadata_path.write_text(json.dumps(metadata, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
        source_path.write_text(str(metadata.get("source_url") or "") + "\n", encoding="utf-8")
        result_path.write_text(json.dumps({
            "status": "succeeded",
            "metadata_file": str(metadata_path),
            "source_url_file": str(source_path),
            "metadata": metadata,
        }, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
        written.update({
            "metadata_file": str(metadata_path),
            "source_url_file": str(source_path),
            "result_file": str(result_path),
        })
    if output_json:
        target = Path(output_json).expanduser()
        target.parent.mkdir(parents=True, exist_ok=True)
        target.write_text(json.dumps(metadata, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
        written["output_json"] = str(target)
    return written


def parse_bool(value: str) -> bool:
    return str(value or "").strip().lower() in {"1", "true", "yes", "y", "on"}


def main() -> int:
    parser = argparse.ArgumentParser(description="Fetch normalized YouTube metadata.")
    parser.add_argument("--source-url", required=True)
    parser.add_argument("--api-url", default=os.environ.get("YOUTUBE_CONTENT_API_URL", ""))
    parser.add_argument("--api-token", default=os.environ.get("YOUTUBE_CONTENT_API_TOKEN", ""))
    parser.add_argument("--timeout-seconds", type=int, default=int(os.environ.get("YOUTUBE_METADATA_TIMEOUT_SECONDS", "30")))
    parser.add_argument("--output-dir", default="")
    parser.add_argument("--output-json", default="")
    parser.add_argument("--include-raw", default="false")
    args = parser.parse_args()

    payload = fetch_metadata(args.source_url, args.api_url, args.api_token, args.timeout_seconds)
    metadata = normalize_metadata(args.source_url, payload, include_raw=parse_bool(args.include_raw))
    written = write_outputs(metadata, args.output_dir, args.output_json)
    result = {
        "status": "succeeded",
        "source_url": args.source_url,
        "metadata": metadata,
        "written": written,
    }
    print(json.dumps(result, ensure_ascii=False, indent=2))
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except Exception as exc:
        print(json.dumps({"status": "failed", "error": str(exc)}, ensure_ascii=False), file=sys.stderr)
        raise SystemExit(1)

